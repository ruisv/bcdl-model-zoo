# Raw salvage pulled off the convert host — unsanitised (absolute paths, host
# names). Kept locally as the recovery source of record; never published.
.salvage/

# Model artefacts. None of these are redistributed from this repo: the recipes
# regenerate them. See README.md "What this repo does and does not ship".
*.onnx
*.hbm
*.bc
*.pth
*.pt
*.pdiparams
checkpoints/

# Calibration data is regenerated by each model's calib.py from public sources.
cal/
cal_*/
*.npy

# Compile by-products
*_out/
hb_compile.log
*.log

__pycache__/
*.pyc
.DS_Store

# Local machine paths (mirrors bcdl's scripts/local.env convention)
local.env
